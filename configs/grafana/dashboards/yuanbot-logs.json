{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "datasource",
      "id": "loki",
      "name": "Loki",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "YuanBot 应用日志监控仪表盘 — 日志量、级别分布、错误追踪、关键词搜索",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "📊 日志吞吐量 (按级别)",
      "description": "各日志级别每分钟的写入速率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (level) (rate({job=\"yuanbot\"} [$__auto]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" },
            "lineWidth": 1
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ERROR" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "WARNING" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "INFO" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "DEBUG" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "title": "🔴 错误 & 告警 日志",
      "description": "实时显示 ERROR 和 CRITICAL 级别日志",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"yuanbot\", level=~\"ERROR|CRITICAL\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "📋 模块日志分布 (Top 10 Logger)",
      "description": "各 Python Logger 模块的日志产出量",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "topk(10, sum by (logger) (count_over_time({job=\"yuanbot\"} [$__range])))",
          "legendFormat": "{{logger}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "title": "⏱️ 错误率趋势",
      "description": "ERROR/CRITICAL 日志占总日志的百分比",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(rate({job=\"yuanbot\", level=~\"ERROR|CRITICAL\"} [$__auto])) / sum(rate({job=\"yuanbot\"} [$__auto])) * 100",
          "legendFormat": "错误率 %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 2
          },
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "🔎 关键事件追踪",
      "description": "包含 event 标签的关键业务事件",
      "type": "logs",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"yuanbot\"} |~ `\"event\":\\s*\"[^\"]+\"`",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "📝 最近日志流",
      "description": "全部 YuanBot 日志实时流",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"yuanbot\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "🐛 错误关键词搜索",
      "description": "常见错误模式匹配（Exception, Traceback, Timeout 等）",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"yuanbot\"} |~ \"(?i)(exception|traceback|timeout|error|fail|crash|panic)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["yuanbot", "logs", "loki"],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "yuanbot",
          "value": "yuanbot"
        },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({job=\"yuanbot\"}, level)",
        "name": "level",
        "label": "日志级别",
        "type": "query",
        "query": "label_values({job=\"yuanbot\"}, level)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+"
      },
      {
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({job=\"yuanbot\"}, logger)",
        "name": "logger",
        "label": "模块",
        "type": "query",
        "query": "label_values({job=\"yuanbot\"}, logger)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "YuanBot 日志监控",
  "uid": "yuanbot-logs-overview",
  "version": 1
}